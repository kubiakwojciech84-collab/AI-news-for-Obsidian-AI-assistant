{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2021",
    "lib": [
      "ES2021",
      "DOM",
      "DOM.Iterable"
    ],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "outDir": "dist",
    "noEmit": true,
    "useDefineForClassFields": false
  },
  "include": [
    "src"
  ]
}
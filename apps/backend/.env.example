NODE_ENV=development
PORT=4000

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=nova
DATABASE_PASSWORD=nova
DATABASE_NAME=nova_worlds

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=2h

CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Shared secret used by apps/game-server to call trusted backend endpoints (achievements, leaderboard).
INTERNAL_API_KEY=dev-internal-key-change-me

# Optional: enables real LLM-driven NPC dialogue via Anthropic's API.
# Leave empty to run NPCs in offline/rule-based fallback mode.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

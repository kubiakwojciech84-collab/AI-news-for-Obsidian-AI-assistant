{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2021", "DOM"],
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@nova/shared": ["packages/shared/src"],
      "@nova/shared/*": ["packages/shared/src/*"],
      "@nova/engine3d": ["packages/engine3d/src"],
      "@nova/engine3d/*": ["packages/engine3d/src/*"],
      "@nova/physics": ["packages/physics/src"],
      "@nova/physics/*": ["packages/physics/src/*"],
      "@nova/networking": ["packages/networking/src"],
      "@nova/networking/*": ["packages/networking/src/*"],
      "@nova/ai": ["packages/ai/src"],
      "@nova/ai/*": ["packages/ai/src/*"],
      "@nova/game-obby": ["games/obby/src"],
      "@nova/game-shooter-fps": ["games/shooter-fps/src"]
    }
  }
}
